{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node20",
    "moduleResolution": "Node16",
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/mcpClient.ts", "src/mcpServer.ts"],
  "exclude": ["node_modules"]
}
